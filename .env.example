# ===========================================
# 分数线登记系统 - 环境变量说明
# ===========================================
# 复制此文件为 .env 并填入实际值
# Render 部署时，敏感变量在 Dashboard 中手动设置

# ---- 数据库 ----
# 本地开发 (PostgreSQL):
#   docker run -d --name fenshu-pg -p 5432:5432 \
#     -e POSTGRES_USER=postgres -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=fenshu postgres:16-alpine
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fenshu"

# ---- 运行模式 ----
NODE_ENV=production

# ---- 端口 ----
PORT=3000

# ---- CORS ----
# 允许跨域访问的前端地址，逗号分隔
CORS_ALLOW_ORIGINS="http://localhost:5173,http://localhost:4173"

# ---- 管理员认证 ----
# 管理员登录密码
ADMIN_PASSWORD=""
# TOTP 密钥（用于生成动态验证码，Base32 格式）
ADMIN_TOTP_SECRET=""
# JWT 签名密钥（随机字符串，至少 32 字符）
ADMIN_JWT_SECRET=""
# JWT Token 有效期（如 15m, 1h, 24h）
ADMIN_TOKEN_TTL="15m"
# TOTP 周期秒数（30 或 60）
ADMIN_TOTP_PERIOD=30
# 登录失败锁定阈值
ADMIN_LOGIN_MAX_FAILURES=5
# 登录锁定分钟数
ADMIN_LOGIN_LOCK_MINUTES=15
# Cookie Secure 标志（生产环境设 true，本地设 false）
ADMIN_COOKIE_SECURE=true
# Cookie SameSite（strict / lax / none）
ADMIN_COOKIE_SAME_SITE=strict

# ---- 成绩提交防护 ----
# 提交令牌有效期（秒）
SCORE_SUBMIT_TOKEN_TTL_SECONDS=300
# 每分钟最大令牌请求数
SCORE_SUBMIT_TOKEN_MAX_PER_MINUTE=20
# IP+姓名窗口期（秒）
SCORE_SUBMIT_IP_NAME_WINDOW_SECONDS=600
# 窗口期内每个 IP 最多提交的不同姓名数
SCORE_SUBMIT_IP_MAX_NAMES=3
# IP 黑名单（逗号分隔）
BLOCKED_SCORE_SUBMIT_IPS=""
